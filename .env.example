# -----------------------------------------------------------------------------
# DATABASE (Prisma + Supabase Postgres)
# -----------------------------------------------------------------------------
# Transactional connection pooler string (ends in ?pgbouncer=true or standard 5432/6543 depends on setup)
DATABASE_URL="postgresql://postgres.[YOUR-SUPABASE-ID]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for Prisma Migrations (ends with 5432)
DIRECT_URL="postgresql://postgres.[YOUR-SUPABASE-ID]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# SUPABASE FRONTEND & STORAGE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-SUPABASE-ID].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# -----------------------------------------------------------------------------
# AUTHENTICATION (Better Auth)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET="your-32-char-random-secret-here"
BETTER_AUTH_URL="http://localhost:3000" # Change to production URL later (e.g. https://yourdomain.com)

# PUBLIC SITE URL (production)
NEXT_PUBLIC_SITE_URL="https://yourdomain.vercel.app"

# -----------------------------------------------------------------------------
# ADMIN SEEDING (Used occasionally or internally if custom logic requires)
# -----------------------------------------------------------------------------
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="SecurePassword123!"
# Only enable this during initial setup. In production, keep it disabled by default.
ENABLE_ADMIN_BOOTSTRAP="false"
